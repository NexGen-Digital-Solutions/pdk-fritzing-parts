  <label>PDK R2E</label>
  <date>2026-07-15</date>
  <url>https://support.pdk.io/hc/en-us/articles/8425047451671-Red-2-Expander-User-Manual</url>
  <tags>
    <tag>PDK</tag>
    <tag>ProdataKey</tag>
